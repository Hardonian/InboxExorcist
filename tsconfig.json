{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@inbox-exorcist/shared-core/*": ["./packages/shared-core/src/*"],
      "@inbox-exorcist/shared-intelligence/*": ["./packages/shared-intelligence/src/*"],
      "@inbox-exorcist/shared-diagnostics/*": ["./packages/shared-diagnostics/src/*"],
      "@inbox-exorcist/shared-cost-control/*": ["./packages/shared-cost-control/src/*"],
      "@inbox-exorcist/shared-infra/*": ["./packages/shared-infra/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
